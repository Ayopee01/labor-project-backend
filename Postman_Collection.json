    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (error) {}",
                  "if (body.access_token) pm.collectionVariables.set('accessToken', body.access_token);",
                  "if (body.refresh_token) pm.collectionVariables.set('refreshToken', body.refresh_token);",
                  "if (body.login_challenge_token) pm.collectionVariables.set('loginChallengeToken', body.login_challenge_token);",
                  "if (body.details && body.details.login_challenge_token) pm.collectionVariables.set('loginChallengeToken', body.details.login_challenge_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text",
                "description": "Required when sending JSON body."
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Method: POST\nURL: {{baseUrl}}/api/auth/login\nAuth: No auth required\nHeaders: Content-Type: application/json\nQuery: None\nBody: Admin login requires username and password only. User login must also send device_id and device_name.\nNotes: Saves access_token and refresh_token into collection variables when login succeeds. Saves login_challenge_token when ACTIVE_SESSION_EXISTS is returned."
          },
          "response": []
        },
        {
          "name": "POST /api/auth/login/confirm-force",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (error) {}",
                  "if (body.access_token) pm.collectionVariables.set('accessToken', body.access_token);",
                  "if (body.refresh_token) pm.collectionVariables.set('refreshToken', body.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text",
                "description": "Required when sending JSON body."
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login_challenge_token\": \"{{loginChallengeToken}}\",\n  \"device_id\": \"{{deviceId}}\",\n  \"device_name\": \"{{deviceName}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login/confirm-force",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login",
                "confirm-force"
              ]
            },
            "description": "Method: POST\nURL: {{baseUrl}}/api/auth/login/confirm-force\nAuth: No auth required\nHeaders: Content-Type: application/json\nQuery: None\nBody: JSON: login_challenge_token, device_id, device_name\nNotes: Use only after login returns ACTIVE_SESSION_EXISTS with a login_challenge_token."
          },
          "response": []
        },
        {
          "name": "POST /api/auth/refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (error) {}",
                  "if (body.access_token) pm.collectionVariables.set('accessToken', body.access_token);",
                  "if (body.refresh_token) pm.collectionVariables.set('refreshToken', body.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text",
                "description": "Required when sending JSON body."
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh"
              ]
            },
            "description": "Method: POST\nURL: {{baseUrl}}/api/auth/refresh\nAuth: No auth required\nHeaders: Content-Type: application/json\nQuery: None\nBody: JSON: refresh_token\nNotes: Returns a new access_token and refresh_token."
          },
          "response": []

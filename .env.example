# Config CORS 
CORS_ORIGIN=*

# Config PORT
PORT=8080

# Prisma PostgreSQL connection
DATABASE_URL=postgresql://postgres:password@localhost:5433/labor_project

# Docker API container -> local PostgreSQL on host machine
DOCKER_DATABASE_URL=postgresql://postgres:password@host.docker.internal:5433/labor_project

# JWT
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_LOGIN_CHALLENGE_SECRET=change-this-login-challenge-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_LOGIN_CHALLENGE_EXPIRES_IN=5m

# Refresh token storage hash
REFRESH_TOKEN_HASH_SECRET=change-this-refresh-token-hash-secret

# Redis / BullMQ worker queue
REDIS_URL=redis://localhost:6380
REDIS_HOST_PORT=6380
REDIS_WORKER_QUEUE_KEY=labor:worker:queue
REDIS_WORKER_STATUS_KEY_PREFIX=labor:worker:status:
REDIS_WORKER_PRESENCE_KEY_PREFIX=labor:worker:presence:
WORKER_PRESENCE_STALE_SECONDS=90
WORKER_SOCKET_DISCONNECT_GRACE_MS=15000
REDIS_WORKER_BREAK_COUNT_KEY_PREFIX=labor:worker:break-count:
BULLMQ_ASSIGNMENT_TIMEOUT_QUEUE=labor-assignment-timeouts
BULLMQ_WORKER_BREAK_RETURN_QUEUE=labor-worker-break-returns
BULLMQ_LINE_MESSAGE_QUEUE=labor-line-messages

# LINE OA
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

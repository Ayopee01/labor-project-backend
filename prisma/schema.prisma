generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id              Int      @id @default(autoincrement())
  username        String   @unique @db.VarChar(100)
  passwordHash    String   @map("password_hash") @db.VarChar(512)
  role            String   @db.VarChar(20)
  status          String   @default("active") @db.VarChar(20)
  fullName        String   @map("full_name") @db.VarChar(255)
  position        String?  @db.VarChar(255)
  email           String?  @db.VarChar(255)
  phone           String?  @db.VarChar(50)
  permissionLevel String?  @map("permission_level") @db.VarChar(50)
  createdBy       Int?     @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  creator         Account?           @relation("AccountCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAccounts Account[]          @relation("AccountCreatedBy")
  profile         WorkerProfile?
  sessions        UserSession[]
  workSchedules   WorkerWorkSchedule[] @relation("ScheduleAccount")
  createdSchedules WorkerWorkSchedule[] @relation("ScheduleCreatedBy")
  updatedSchedules WorkerWorkSchedule[] @relation("ScheduleUpdatedBy")
  jobAssignments VehicleJobAssignment[] @relation("AssignmentWorker")
  permissions     AccountPermission[]
  ticketWorkers   TicketWorker[]
  submittedTicketCompletions TicketCompletionSubmission[] @relation("TicketCompletionSubmitter")

  @@map("accounts")
}

model SystemSetting {
  key       String   @id @db.VarChar(100)
  value     String   @db.VarChar(255)
  updatedBy Int?     @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@map("system_settings")
}

model AccountPermission {
  id         Int      @id @default(autoincrement())
  accountId  Int      @map("account_id")
  permission String   @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([accountId, permission])
  @@index([permission])
  @@map("account_permissions")
}

model GateRequestLog {
  id                 Int      @id @default(autoincrement())
  gateTransactionRef String   @unique @map("gate_transaction_ref") @db.VarChar(100)
  vehicleJobId       Int?     @map("vehicle_job_id")
  payloadSnapshot    Json     @map("payload_snapshot")
  responseSnapshot   Json?    @map("response_snapshot")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp(3)

  vehicleJob VehicleJob? @relation(fields: [vehicleJobId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("gate_request_logs")
}

model VehicleJob {
  id                Int      @id @default(autoincrement())
  vehicleJobRef     String   @unique @map("vehicle_job_ref") @db.VarChar(100)
  gateTransactionRef String  @map("gate_transaction_ref") @db.VarChar(100)
  licensePlate      String   @map("license_plate") @db.VarChar(50)
  vehicleType       String?  @map("vehicle_type") @db.VarChar(100)
  workersRequired   Int      @map("workers_required")
  status            String   @default("WAIT") @db.VarChar(30)
  driverQrToken     String   @unique @map("driver_qr_token") @db.VarChar(255)
  workerQrToken     String   @unique @map("worker_qr_token") @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  gateRequests GateRequestLog[]
  marketJobs MarketJob[]
  tickets GateTicket[]
  driverSessions DriverSession[]
  assignments VehicleJobAssignment[]

  @@index([status])
  @@map("vehicle_jobs")
}

model MarketJob {
  id           Int      @id @default(autoincrement())
  vehicleJobId Int      @map("vehicle_job_id")
  marketJobRef String   @map("market_job_ref") @db.VarChar(100)
  marketName   String   @map("market_name") @db.VarChar(255)
  status       String   @default("WAIT") @db.VarChar(30)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  vehicleJob VehicleJob @relation(fields: [vehicleJobId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tickets GateTicket[]

  @@unique([vehicleJobId, marketJobRef])
  @@index([vehicleJobId, status])
  @@map("market_jobs")
}

model GateTicket {
  id           Int       @id @default(autoincrement())
  vehicleJobId Int       @map("vehicle_job_id")
  marketJobId  Int       @map("market_job_id")
  stallJobRef  String    @map("stall_job_ref") @db.VarChar(100)
  ticketNo     String?   @map("ticket_no") @db.VarChar(100)
  stallNo      String?   @map("stall_no") @db.VarChar(100)
  vendorName   String?   @map("vendor_name") @db.VarChar(255)
  vendorLineId String?   @map("vendor_line_id") @db.VarChar(255)
  status       String    @default("WAIT") @db.VarChar(30)
  confirmationStatus String @default("WAIT") @map("confirmation_status") @db.VarChar(30)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamp(3)

  vehicleJob VehicleJob @relation(fields: [vehicleJobId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  marketJob MarketJob @relation(fields: [marketJobId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products TicketProduct[]
  workers TicketWorker[]
  completionSubmissions TicketCompletionSubmission[]

  @@unique([marketJobId, stallJobRef])
  @@index([ticketNo])
  @@index([marketJobId, status])
  @@map("gate_tickets")
}

model TicketWorker {
  id              Int      @id @default(autoincrement())
  ticketId        Int      @map("ticket_id")
  workerAccountId Int      @map("worker_account_id")
  status          String   @default("IN_PROGRESS") @db.VarChar(30)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  ticket GateTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  worker Account @relation(fields: [workerAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([ticketId, workerAccountId])
  @@index([workerAccountId, status])
  @@map("ticket_workers")
}

model TicketCompletionSubmission {
  id                         Int       @id @default(autoincrement())
  ticketId                   Int       @map("ticket_id")
  submittedByWorkerAccountId Int       @map("submitted_by_worker_account_id")
  status                     String    @default("DELIVERED") @db.VarChar(30)
  confirmedAt                DateTime? @map("confirmed_at") @db.Timestamp(3)
  rejectedAt                 DateTime? @map("rejected_at") @db.Timestamp(3)
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt                  DateTime  @updatedAt @map("updated_at") @db.Timestamp(3)

  ticket GateTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  submittedByWorker Account @relation("TicketCompletionSubmitter", fields: [submittedByWorkerAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([ticketId, status])
  @@map("ticket_completion_submissions")
}

model MessageDeliveryLog {
  id          Int       @id @default(autoincrement())
  channel     String    @db.VarChar(50)
  jobName     String    @map("job_name") @db.VarChar(100)
  target      String?   @db.VarChar(255)
  status      String    @default("PENDING") @db.VarChar(30)
  payload     Json
  lastError   String?   @map("last_error") @db.Text
  sentAt      DateTime? @map("sent_at") @db.Timestamp(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([channel, status])
  @@map("message_delivery_logs")
}

model TicketProduct {
  id                Int      @id @default(autoincrement())
  ticketId          Int      @map("ticket_id")
  productRef        String   @map("product_ref") @db.VarChar(100)
  productType       String?  @map("product_type") @db.VarChar(100)
  name              String   @db.VarChar(255)
  quantity          Decimal  @db.Decimal(12, 2)
  confirmedQuantity Decimal? @map("confirmed_quantity") @db.Decimal(12, 2)
  unit              String   @db.VarChar(50)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  ticket GateTicket @relation(fields: [ticketId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([ticketId, productRef])
  @@index([ticketId])
  @@map("ticket_products")
}

model DriverSession {
  id           Int       @id @default(autoincrement())
  vehicleJobId Int       @map("vehicle_job_id")
  sessionToken String    @unique @map("session_token") @db.VarChar(255)
  expiresAt    DateTime  @map("expires_at") @db.Timestamp(3)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamp(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamp(3)

  vehicleJob VehicleJob @relation(fields: [vehicleJobId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([vehicleJobId])
  @@map("driver_sessions")
}

model VehicleJobAssignment {
  id             Int       @id @default(autoincrement())
  vehicleJobId   Int       @map("vehicle_job_id")
  workerAccountId Int      @map("worker_account_id")
  status         String    @default("PENDING") @db.VarChar(30)
  acceptDeadlineAt DateTime? @map("accept_deadline_at") @db.Timestamp(3)
  scanDeadlineAt DateTime? @map("scan_deadline_at") @db.Timestamp(3)
  acceptedAt     DateTime? @map("accepted_at") @db.Timestamp(3)
  scannedAt      DateTime? @map("scanned_at") @db.Timestamp(3)
  completedAt    DateTime? @map("completed_at") @db.Timestamp(3)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamp(3)

  vehicleJob VehicleJob @relation(fields: [vehicleJobId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  worker Account @relation("AssignmentWorker", fields: [workerAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([workerAccountId, status])
  @@index([vehicleJobId, status])
  @@map("vehicle_job_assignments")
}

model WorkerProfile {
  id              Int     @id @default(autoincrement())
  accountId       Int     @unique @map("account_id")
  imageUrl        String? @map("image_url") @db.VarChar(512)
  nationality     String  @db.VarChar(100)
  workStartDate   String  @map("work_start_date") @db.Char(10)
  shirtType       String? @map("shirt_type") @db.VarChar(50)
  shirtNumber     String? @unique @map("shirt_number") @db.VarChar(50)

  account Account @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("worker_profiles")
}

model UserSession {
  id               Int       @id @default(autoincrement())
  accountId        Int       @map("account_id")
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(512)
  deviceId         String    @map("device_id") @db.VarChar(255)
  deviceName       String    @map("device_name") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  isActive         Boolean   @default(true) @map("is_active")
  lastActiveAt     DateTime  @default(now()) @map("last_active_at") @db.Timestamp(3)
  expiresAt        DateTime  @map("expires_at") @db.Timestamp(3)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamp(3)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamp(3)

  account Account @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([accountId, isActive])
  @@map("user_sessions")
}

model WorkerWorkSchedule {
  id             Int      @id @default(autoincrement())
  accountId      Int      @map("account_id")
  shiftNo        Int      @default(1) @map("shift_no")
  workDate       String   @map("work_date") @db.Char(10)
  shiftStartTime String   @map("shift_start_time") @db.Char(5)
  shiftEndTime   String   @map("shift_end_time") @db.Char(5)
  isCurrent      Boolean  @default(true) @map("is_current")
  createdBy      Int?     @map("created_by")
  updatedBy      Int?     @map("updated_by")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  account          Account  @relation("ScheduleAccount", fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdByAccount Account? @relation("ScheduleCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByAccount Account? @relation("ScheduleUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([accountId, isCurrent])
  @@map("worker_work_schedules")
}
